{
	"name": "todo-projects",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview",
		"lint": "oxlint --fix",
		"typecheck": "vue-tsc --noEmit",
		"fmt": "oxfmt --write .",
		"format": "pnpm lint && pnpm fmt && pnpm typecheck"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.3.0",
		"tailwindcss": "^4.3.0",
		"vue": "^3.5.35"
	},
	"devDependencies": {
		"@types/node": "^25.9.2",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vue/tsconfig": "^0.9.1",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"typescript": "~6.0.3",
		"vite": "^8.0.16",
		"vue-tsc": "^3.3.4"
	}
}
